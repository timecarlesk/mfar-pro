\@writefile{toc}{\contentsline {subsection}{\numberline {2.5}Stage 3: Per-Document Re-Ranking with [RELEVANT] Tags}{3}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.6}Self-Verification Feedback (Memory v2)}{4}}
